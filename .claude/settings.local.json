{
  "permissions": {
    "allow": [
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(pkill *)",
      "Bash(git --version)",
      "Read(//Users/osvaldsoza/.config/gh/**)",
      "Bash(curl -s https://api.github.com/user -H \"Authorization: token $\\(cat ~/.config/gh/hosts.yml)",
      "Bash(gh auth *)",
      "Bash(/opt/homebrew/bin/gh auth *)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(/opt/homebrew/bin/gh repo *)",
      "Bash(git push *)",
      "Skill(update-config)",
      "Skill(update-config:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/osvaldsoza/Development/claude-project && /usr/bin/git add -A && if ! /usr/bin/git diff --cached --quiet; then /usr/bin/git commit -m \"Auto-update: $(/bin/date '+%Y-%m-%d %H:%M:%S')\" && /usr/bin/git push origin main; fi 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Sincronizando com GitHub..."
          }
        ]
      }
    ]
  }
}
